#-----------------------------------------------------------------------------
# Variables needed by the Makefile
#-----------------------------------------------------------------------------

#-----------------------------------------------------------------------------
# Default build type: release / debug
#-----------------------------------------------------------------------------
BUILD_TYPE?=debug

#-----------------------------------------------------------------------------
# Top level directories
#-----------------------------------------------------------------------------
SRC_DIR=$(PROJECT_BASE_DIR)/src

IFACE_DIR=$(SRC_DIR)/interface

APPS_DIR=$(SRC_DIR)/apps

HUB_DIR=$(SRC_DIR)/hub

KTLIB_DIR=$(SRC_DIR)/KtLib

SCRIPTS_DIR=$(SRC_DIR)/scripts

OUTPUT_DIR=$(BUILD_DIR)/output

#-----------------------------------------------------------------------------
# Linux OS utility macros
#-----------------------------------------------------------------------------
MKDIR=mkdir -p
RM=rm -rf
CD=cd
FIND_IN=find
COPY=cp -rv
COPY_FROM_LINK=rsync -l
PYTHON=python3
MAKE_EXECUTABLE=chmod +x
CMAKE=cmake

export
