#-----------------------------------------------------------------------------
# Makefile for APPS
#-----------------------------------------------------------------------------

#-----------------------------------------------------------------------------
# Phony targets
#-----------------------------------------------------------------------------
.PHONY: all build clean

#-----------------------------------------------------------------------------
# targets
#-----------------------------------------------------------------------------
all: build

build: build_kt_app

build_kt_app:
	$(MAKE) -C $(KT_APP_DIR) build

clean:
	$(MAKE) -C $(KT_APP_DIR) clean